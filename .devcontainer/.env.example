# === Development Environment Configuration ===
# Copy this file to .env and fill in your values

# === LLM Configuration ===
# At least one API key is required for content generation

# OpenAI (or compatible provider like Ollama, DeepSeek, OpenRouter)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic (alternative to OpenAI)
# ANTHROPIC_API_KEY=your_anthropic_api_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# LLM Provider Selection
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini

# === Social Media Configuration ===
# Only configure the platforms you want to use

# Facebook (Primary platform)
# Get from: developers.facebook.com → Graph API Explorer
# Required permissions: pages_manage_posts, pages_read_engagement
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Twitter/X API v2 (Fallback)
TWITTER_API_KEY=
TWITTER_API_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_SECRET=
TWITTER_BEARER_TOKEN=

# Telegram Bot (Fallback)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# === Database ===
DATABASE_PATH=./data/koldb.sqlite

# === Content Generation ===
CONTENT_LANGUAGE=vi
MAX_POST_TOKENS=2000

# === Scheduling ===
# Cron expression for content generation (default: every 4 hours)
CONTENT_SCHEDULE="0 */4 * * *"

# === Server ===
PORT=3000
HOST=0.0.0.0

# === Development Settings ===
NODE_ENV=development
