# === AI KOL Configuration ===

# LLM API Keys (at least one required for content generation)
OPENAI_API_KEY=sk-...
# Custom endpoint for OpenAI-compatible providers (Ollama, DeepSeek, OpenRouter, vLLM, etc.)
OPENAI_BASE_URL=https://opencode.ai/zen/go/v1

ANTHROPIC_API_KEY=sk-ant-...
# Custom endpoint for Anthropic-compatible proxies (OpenRouter, AWS Bedrock, etc.)
# ANTHROPIC_BASE_URL=https://api.openrouter.ai/v1

# Default LLM provider: "openai" | "anthropic"
LLM_PROVIDER=openai
LLM_MODEL=glm-5.2

# === Social Media API Keys ===

# Facebook (primary platform)
# Get Page Access Token: developers.facebook.com → Graph API Explorer
# Required permissions: pages_manage_posts, pages_read_engagement
FACEBOOK_PAGE_ID=...
FACEBOOK_PAGE_ACCESS_TOKEN=...

# Twitter/X API v2 (fallback)
TWITTER_API_KEY=...
TWITTER_API_SECRET=...
TWITTER_ACCESS_TOKEN=...
TWITTER_ACCESS_SECRET=...
TWITTER_BEARER_TOKEN=...

# Telegram Bot (fallback)
TELEGRAM_BOT_TOKEN=...
TELEGRAM_CHAT_ID=...

# === Database ===
DATABASE_PATH=./data/koldb.sqlite

# === Content Generation ===
# Language for content generation
CONTENT_LANGUAGE=vi
# Max tokens per generated post
MAX_POST_TOKENS=2000

# === Scheduling ===
# Cron expression for content generation (default: every 4 hours)
CONTENT_SCHEDULE="0 */4 * * *"

# === Server ===
PORT=3000
HOST=0.0.0.0
