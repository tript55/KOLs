# ==========================================
# Frontend Environment Variables
# ==========================================

# The base path for GitHub Pages (e.g. /crypto-kol/)
# Leave empty or / for custom domains / root deployment
VITE_BASE_PATH=/crypto-kol/

# The URL for your backend API
# For local development with proxy: /api
# For production/GitHub pages: https://your-backend-domain.com/api
VITE_API_URL=https://your-production-backend.com/api
