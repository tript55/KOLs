{
  "name": "crypto-kol",
  "version": "0.1.0",
  "description": "AI KOL for Vietnamese crypto/finance market — automated content generation, scheduling, and social publishing",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "test": "npx tsx --test src/**/*.test.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:seed": "tsx src/db/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^11.3.0",
    "@supabase/supabase-js": "^2.110.7",
    "cron-parser": "^5.6.2",
    "dotenv": "^16.4.7",
    "fastify": "^5.2.0",
    "node-cron": "^3.0.3",
    "openai": "^4.83.0",
    "postgres": "^3.4.9",
    "twitter-api-v2": "^1.18.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/node": "^22.12.0",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
